    {
      "id": "u2bnU3ayke8CWxCUUQhyh",
      "type": "text",
      "x": 188.80007934570312,
      "y": 1322.5,
      "width": 1287.3992919921875,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ai",
      "roundness": null,
      "seed": 1521473722,
      "version": 304,
      "versionNonce": 1747331514,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783090105566,
      "link": null,
      "locked": false,
      "text": "Out of Scope Requirements :\n\n1. Real physical IoT deployment        -      PDF says no physical hardware required\n2. Real 220V AC wiring                  -      Unsafe and unnecessary\n3. Device control from dashboard     -      PS asks monitoring, not control\n4. User/person tracking                 -      Privacy risk and not required\n5. Smart billing integration             -       Too much for MVP\n6. Advanced ML forecasting           -      Nice future feature, not needed\n7. Mobile app                             -      Web dashboard + Discord bot already enough\n8. Multi-office support                 -      Future scalability feature(Multiple offices → hundreds of rooms → thousands of devices)\n9. Payment/billing system              -      Not relevant\n10. Complex authentication            -      Can add simple admin token only",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Out of Scope Requirements :\n\n1. Real physical IoT deployment        -      PDF says no physical hardware required\n2. Real 220V AC wiring                  -      Unsafe and unnecessary\n3. Device control from dashboard     -      PS asks monitoring, not control\n4. User/person tracking                 -      Privacy risk and not required\n5. Smart billing integration             -       Too much for MVP\n6. Advanced ML forecasting           -      Nice future feature, not needed\n7. Mobile app                             -      Web dashboard + Discord bot already enough\n8. Multi-office support                 -      Future scalability feature(Multiple offices → hundreds of rooms → thousands of devices)\n9. Payment/billing system              -      Not relevant\n10. Complex authentication            -      Can add simple admin token only",
      "autoResize": true,
      "lineHeight": 1.25
    },
